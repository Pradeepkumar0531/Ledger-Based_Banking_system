# LedgerPay Backend - Environment Variables Template

# MongoDB Connection String
# Get from: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/backend-ledger

# JWT Secret for token signing (generate a secure random string)
# You can use: openssl rand -base64 32
JWT_SECRET=your-secure-random-jwt-secret-here

# Gmail OAuth2 Credentials
# Get from: https://console.cloud.google.com/
CLIENT_ID=your-google-client-id.apps.googleusercontent.com
CLIENT_SECRET=your-google-client-secret

# Gmail OAuth2 Refresh Token
# Get from: https://myaccount.google.com/connections
REFRESH_TOKEN=your-google-refresh-token

# Email user for sending notifications
EMAIL_USER=your-email@gmail.com

# Node Environment
NODE_ENV=production

# Server Port (optional, defaults to 5000)
PORT=5000
